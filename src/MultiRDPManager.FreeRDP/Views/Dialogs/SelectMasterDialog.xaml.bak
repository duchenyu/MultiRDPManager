<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.SelectMasterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MultiRDPManager.FreeRDP.Models"
        Title="选择主控窗口"
        Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e"
        Foreground="#cdd6f4"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <!-- 服务器显示模板 -->
        <DataTemplate x:Key="ServerItemTemplate" DataType="{x:Type models:RdpSession}">
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <TextBlock Text="{Binding ServerName}" FontSize="14" FontWeight="SemiBold" Foreground="#cdd6f4" />
                <TextBlock Text="  (" FontSize="12" Foreground="#6c7086" />
                <TextBlock Text="{Binding IpAddress}" FontSize="12" Foreground="#6c7086" />
                <TextBlock Text=":" FontSize="12" Foreground="#6c7086" />
                <TextBlock Text="{Binding Port}" FontSize="12" Foreground="#6c7086" />
                <TextBlock Text=")" FontSize="12" Foreground="#6c7086" />
            </StackPanel>
        </DataTemplate>

        <Style TargetType="ListBoxItem" x:Key="RadioListBoxItemStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent" Padding="4,4"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#313244">
                            <RadioButton IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                                         GroupName="MasterSelection"
                                         Focusable="False">
                                <RadioButton.Content>
                                    <ContentPresenter ContentTemplate="{StaticResource ServerItemTemplate}"
                                                      Content="{Binding}" />
                                </RadioButton.Content>
                            </RadioButton>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#313244" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 提示文字 -->
        <TextBlock Grid.Row="0" Text="请选择以下哪台服务器作为主控窗口："
                   FontSize="14" Margin="0,0,0,12"
                   Foreground="#a6adc8"
                   TextWrapping="Wrap" />

        <!-- 服务器列表（单选） -->
        <ListBox Grid.Row="1" x:Name="ServerListBox"
                 ItemsSource="{Binding}"
                 SelectionMode="Single"
                 Background="#181825"
                 BorderBrush="#313244"
                 BorderThickness="1"
                 Foreground="#cdd6f4"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemContainerStyle="{StaticResource RadioListBoxItemStyle}" />

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton"
                    Content="取消"
                    Width="80" Height="32"
                    Margin="0,0,8,0"
                    Background="#313244"
                    Foreground="#cdd6f4"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="OnCancelClick" />
            <Button x:Name="OkButton"
                    Content="确认"
                    Width="80" Height="32"
                    Background="#89b4fa"
                    Foreground="#1e1e2e"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="Bold"
                    Click="OnOkClick" />
        </StackPanel>
    </Grid>
</Window>
