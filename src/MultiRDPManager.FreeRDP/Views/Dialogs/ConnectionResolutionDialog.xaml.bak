<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.ConnectionResolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置远程桌面分辨率"
        Height="260" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background}"
        Foreground="{StaticResource Brush_TextPrimary}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="设置连接分辨率" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,16" />

        <!-- 表单 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="宽度 (Width):" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="WidthTextBox" Text="2560"
                         VerticalContentAlignment="Center" Height="28" />
                <TextBlock Grid.Column="2" Text=" px" VerticalAlignment="Center" Margin="6,0,0,0"
                           Foreground="{StaticResource Brush_TextSecondary}" />
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="高度 (Height):" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="HeightTextBox" Text="1440"
                         VerticalContentAlignment="Center" Height="28" />
                <TextBlock Grid.Column="2" Text=" px" VerticalAlignment="Center" Margin="6,0,0,0"
                           Foreground="{StaticResource Brush_TextSecondary}" />
            </Grid>

            <TextBlock Text="分辨率设置将应用于本次及后续所有连接，直到修改。"
                       FontSize="11" Foreground="{StaticResource Brush_TextSecondary}"
                       Margin="0,8,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="80" Height="30" Margin="0,0,8,0"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnCancelClick" />
            <Button Content="确定" Width="80" Height="30"
                    Background="{StaticResource Brush_SelectedHighlight}"
                    Foreground="White"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnConfirmClick" />
        </StackPanel>
    </Grid>
</Window>
