<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.ImportCsvDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Servers from CSV"
        Height="520" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background}"
        Foreground="{StaticResource Brush_TextPrimary}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        BorderThickness="1"
        BorderBrush="{StaticResource Brush_Border}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Import Servers from CSV"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="Bulk add servers via CSV format"
                       FontSize="12"
                       Foreground="{StaticResource Brush_TextTertiary}"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0" />
        </Grid>

        <!-- 格式提示 -->
        <Border Grid.Row="1"
                Background="{StaticResource Brush_InfoBg}"
                BorderBrush="{StaticResource Brush_Info}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Format: "
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush_Info}"
                           VerticalAlignment="Center" />
                <TextBlock Text="Name, IP, Username, Password"
                           FontSize="12"
                           Foreground="{StaticResource Brush_Info}"
                           VerticalAlignment="Center" />
                <TextBlock Text="(comma/tab separated, default port 3389)"
                           FontSize="11"
                           Foreground="{StaticResource Brush_TextTertiary}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- CSV 文本输入区 -->
        <Border Grid.Row="2"
                Background="{StaticResource Brush_Surface}"
                CornerRadius="8"
                BorderBrush="{StaticResource Brush_Border}"
                BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 提示栏 -->
                <Border Grid.Row="0"
                        Background="{StaticResource Brush_ToolbarBackground}"
                        Padding="10,6"
                        CornerRadius="8,8,0,0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{StaticResource Brush_Border}">
                    <TextBlock Text="Paste CSV content below (copy from Excel / text directly)"
                               FontSize="11"
                               Foreground="{StaticResource Brush_TextSecondary}" />
                </Border>

                <!-- 文本输入框 -->
                <TextBox Grid.Row="1" x:Name="CsvTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         FontFamily="{StaticResource Font_Monospace}"
                         FontSize="12"
                         Padding="10"
                         Background="{StaticResource Brush_Background}"
                         Foreground="{StaticResource Brush_TextPrimary}"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         TextChanged="OnCsvTextChanged" />

                <!-- 解析状态栏 -->
                <Border Grid.Row="2"
                        Background="{StaticResource Brush_ToolbarBackground}"
                        Padding="10,6"
                        CornerRadius="0,0,8,8"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource Brush_Border}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ParseStatusDot"
                                 Width="6" Height="6"
                                 Fill="{StaticResource Brush_TextTertiary}"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="ParseStatusText"
                                   Text="Paste CSV data for auto-parse..."
                                   FontSize="11"
                                   Foreground="{StaticResource Brush_TextSecondary}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 预览 / 按钮栏 -->
        <Border Grid.Row="3"
                Background="{StaticResource Brush_Surface}"
                CornerRadius="8"
                BorderBrush="{StaticResource Brush_Border}"
                BorderThickness="1"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 预览信息 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Preview: "
                               FontSize="11"
                               Foreground="{StaticResource Brush_TextTertiary}" />
                    <TextBlock x:Name="PreviewInfoText"
                               Text="Waiting for input..."
                               FontSize="11"
                               Foreground="{StaticResource Brush_TextSecondary}" />
                </StackPanel>

                <!-- 按钮组 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Clear"
                            Style="{StaticResource SecondaryActionButton}"
                            Height="30"
                            MinWidth="60"
                            Padding="10,0"
                            Click="OnClearClick" />
                    <Button Content="Cancel"
                            Style="{StaticResource SecondaryActionButton}"
                            Height="30"
                            MinWidth="60"
                            Padding="10,0"
                            Margin="8,0,0,0"
                            Click="OnCancelClick" />
                    <Button x:Name="ImportButton"
                            Content="Import"
                            Style="{StaticResource PrimaryActionButton}"
                            Height="30"
                            MinWidth="80"
                            IsEnabled="False"
                            Click="OnImportClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
