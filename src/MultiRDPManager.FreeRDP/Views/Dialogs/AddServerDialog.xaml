<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.AddServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加服务器"
        Height="400" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background}"
        Foreground="{StaticResource Brush_TextPrimary}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        BorderThickness="1"
        BorderBrush="{StaticResource Brush_Border}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="添加远程服务器"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="添加一台新的远程桌面服务器"
                       FontSize="12"
                       Foreground="{StaticResource Brush_TextTertiary}"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0" />
        </Grid>

        <!-- 表单 -->
        <StackPanel Grid.Row="1">
            <!-- 名称 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="名称"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="NameTextBox"
                         ToolTip="服务器显示名称" />
            </Grid>

            <!-- IP 地址 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="IP 地址"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="IpTextBox"
                         ToolTip="远程服务器的 IP 地址" />
            </Grid>

            <!-- 端口 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="端口"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="PortTextBox" Text="3389"
                         ToolTip="默认 3389（RDP 标准端口）" />
                <TextBlock Grid.Column="2"
                           Text="默认 3389"
                           FontSize="11"
                           Foreground="{StaticResource Brush_TextTertiary}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>

            <!-- 用户名 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="用户名"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="UsernameTextBox"
                         ToolTip="远程桌面登录用户名" />
            </Grid>

            <!-- 密码 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="密码"
                           Style="{StaticResource DialogLabelStyle}" />
                <PasswordBox Grid.Column="1" x:Name="PasswordBox"
                             ToolTip="远程桌面登录密码" />
            </Grid>
        </StackPanel>

        <!-- 按钮 -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource Brush_Border}"
                Padding="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Style="{StaticResource SecondaryActionButton}"
                        Click="OnCancelClick" />
                <Button Content="确定"
                        Style="{StaticResource PrimaryActionButton}"
                        Margin="10,0,0,0"
                        Click="OnConfirmClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
