<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.AddServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Server"
        Height="400" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background}"
        Foreground="{StaticResource Brush_TextPrimary}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        BorderThickness="1"
        BorderBrush="{StaticResource Brush_Border}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Add Remote Server"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="Add a new remote desktop server"
                       FontSize="12"
                       Foreground="{StaticResource Brush_TextTertiary}"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0" />
        </Grid>

        <!-- 表单 -->
        <StackPanel Grid.Row="1">
            <!-- 名称 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Name"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="NameTextBox"
                         ToolTip="Server display name" />
            </Grid>

            <!-- IP 地址 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="IP Address"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="IpTextBox"
                         ToolTip="Remote server IP address" />
            </Grid>

            <!-- 端口 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Port"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="PortTextBox" Text="3389"
                         ToolTip="Default 3389 (RDP standard port)" />
                <TextBlock Grid.Column="2"
                           Text="Default 3389"
                           FontSize="11"
                           Foreground="{StaticResource Brush_TextTertiary}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>

            <!-- 用户名 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Username"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="UsernameTextBox"
                         ToolTip="Remote desktop login username" />
            </Grid>

            <!-- 密码 -->
            <Grid Style="{StaticResource DialogFormRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Password"
                           Style="{StaticResource DialogLabelStyle}" />
                <PasswordBox Grid.Column="1" x:Name="PasswordBox"
                             ToolTip="Remote desktop login password" />
            </Grid>
        </StackPanel>

        <!-- 按钮 -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource Brush_Border}"
                Padding="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryActionButton}"
                        Click="OnCancelClick" />
                <Button Content="OK"
                        Style="{StaticResource PrimaryActionButton}"
                        Margin="10,0,0,0"
                        Click="OnConfirmClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
