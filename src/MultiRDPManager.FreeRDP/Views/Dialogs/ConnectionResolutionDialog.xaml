<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.ConnectionResolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Remote Desktop Resolution"
        Height="280" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background}"
        Foreground="{StaticResource Brush_TextPrimary}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        BorderThickness="1"
        BorderBrush="{StaticResource Brush_Border}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Set Connection Resolution"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="Configure the display resolution of the remote desktop"
                       FontSize="12"
                       Foreground="{StaticResource Brush_TextTertiary}"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0" />
        </Grid>

        <!-- 表单 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!-- 宽度 -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Width"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="WidthTextBox"
                         Text="2560"
                         VerticalContentAlignment="Center"
                         Height="30" />
                <TextBlock Grid.Column="2"
                           Text="px"
                           FontSize="12"
                           Foreground="{StaticResource Brush_TextTertiary}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>

            <!-- 高度 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Height"
                           Style="{StaticResource DialogLabelStyle}" />
                <TextBox Grid.Column="1" x:Name="HeightTextBox"
                         Text="1440"
                         VerticalContentAlignment="Center"
                         Height="30" />
                <TextBlock Grid.Column="2"
                           Text="px"
                           FontSize="12"
                           Foreground="{StaticResource Brush_TextTertiary}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>

            <!-- 提示 -->
            <Border Background="{StaticResource Brush_InfoBg}"
                    BorderBrush="{StaticResource Brush_Info}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,8"
                    Margin="0,6,0,0">
                <TextBlock Text="The resolution setting will apply to this and all future connections until changed."
                           FontSize="11"
                           Foreground="{StaticResource Brush_Info}"
                           TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <!-- 按钮 -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource Brush_Border}"
                Padding="0,16,0,0"
                Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryActionButton}"
                        Click="OnCancelClick" />
                <Button Content="OK"
                        Style="{StaticResource PrimaryActionButton}"
                        Margin="10,0,0,0"
                        Click="OnConfirmClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
