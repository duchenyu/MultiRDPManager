<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.SelectMasterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MultiRDPManager.FreeRDP.Models"
        Title="选择主控窗口"
        Width="440" Height="350"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background}"
        Foreground="{StaticResource Brush_TextPrimary}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        BorderThickness="1"
        BorderBrush="{StaticResource Brush_Border}">

    <Window.Resources>
        <DataTemplate x:Key="ServerItemTemplate" DataType="{x:Type models:RdpSession}">
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <Ellipse Width="8" Height="8"
                         Fill="{StaticResource Brush_Success}"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center" />
                <StackPanel>
                    <TextBlock Text="{Binding ServerName}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource Brush_TextTertiary}">
                        <Run Text="{Binding IpAddress}" />
                        <Run Text=":" />
                        <Run Text="{Binding Port}" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="选择主控窗口"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="选择群控模式中的主控服务器"
                       FontSize="12"
                       Foreground="{StaticResource Brush_TextTertiary}"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0" />
        </Grid>

        <!-- 提示文字 -->
        <TextBlock Grid.Row="0"
                   Text="已勾选以下服务器，请选择一台作为主控："
                   FontSize="13"
                   Foreground="{StaticResource Brush_TextSecondary}"
                   Margin="0,32,0,12"
                   TextWrapping="Wrap" />

        <!-- 服务器列表 -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource Brush_Border}"
                BorderThickness="1"
                CornerRadius="6">
            <ListBox x:Name="ServerListBox"
                     ItemsSource="{Binding}"
                     ItemTemplate="{StaticResource ServerItemTemplate}"
                     SelectionMode="Single"
                     Background="{StaticResource Brush_Background}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource DialogListBoxItemStyle}" />
        </Border>

        <!-- 按钮 -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource Brush_Border}"
                Padding="0,16,0,0"
                Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="取消"
                        Style="{StaticResource SecondaryActionButton}"
                        Click="OnCancelClick" />
                <Button x:Name="OkButton"
                        Content="确认"
                        Style="{StaticResource PrimaryActionButton}"
                        Margin="10,0,0,0"
                        Click="OnOkClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
