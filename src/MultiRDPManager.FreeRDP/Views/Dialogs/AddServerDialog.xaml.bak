<Window x:Class="MultiRDPManager.FreeRDP.Views.Dialogs.AddServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加服务器" Height="380" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background}"
        Foreground="{StaticResource Brush_TextPrimary}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="添加远程服务器" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,16" />

        <!-- 表单 -->
        <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="名称:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="NameTextBox" />
            </Grid>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="IP地址:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="IpTextBox" />
            </Grid>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="端口:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="PortTextBox" Text="3389" />
            </Grid>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="用户名:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="UsernameTextBox" />
            </Grid>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="密码:" VerticalAlignment="Center" />
                <PasswordBox Grid.Column="1" x:Name="PasswordBox" />
            </Grid>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="80" Height="30" Margin="0,0,8,0"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnCancelClick" />
            <Button Content="确定" Width="80" Height="30"
                    Background="{StaticResource Brush_SelectedHighlight}"
                    Foreground="White"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnConfirmClick" />
        </StackPanel>
    </Grid>
</Window>
