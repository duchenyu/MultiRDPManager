<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════ -->
    <!-- 全局颜色                                -->
    <!-- ════════════════════════════════════════ -->
    <Color x:Key="Color_Background">#222730</Color>
    <Color x:Key="Color_ToolbarBackground">#2c313a</Color>
    <Color x:Key="Color_Divider">#444a55</Color>
    <Color x:Key="Color_CardBackground">#353b48</Color>
    <Color x:Key="Color_SelectedHighlight">#165dff</Color>
    <Color x:Key="Color_TextPrimary">#f0f2f5</Color>
    <Color x:Key="Color_TextSecondary">#a0a4ab</Color>
    <Color x:Key="Color_Online">#00b42a</Color>
    <Color x:Key="Color_Offline">#86909c</Color>
    <Color x:Key="Color_GroupControlBorder">#ff4d4f</Color>
    <Color x:Key="Color_Error">#e84749</Color>
    <Color x:Key="Color_HoverBackground">#3a4050</Color>
    <Color x:Key="Color_PressedBackground">#1a1d24</Color>
    <Color x:Key="Color_ThumbnailBackground">#1a1d24</Color>

    <!-- 全局画刷 -->
    <SolidColorBrush x:Key="Brush_Background" Color="{StaticResource Color_Background}" />
    <SolidColorBrush x:Key="Brush_ToolbarBackground" Color="{StaticResource Color_ToolbarBackground}" />
    <SolidColorBrush x:Key="Brush_Divider" Color="{StaticResource Color_Divider}" />
    <SolidColorBrush x:Key="Brush_CardBackground" Color="{StaticResource Color_CardBackground}" />
    <SolidColorBrush x:Key="Brush_SelectedHighlight" Color="{StaticResource Color_SelectedHighlight}" />
    <SolidColorBrush x:Key="Brush_TextPrimary" Color="{StaticResource Color_TextPrimary}" />
    <SolidColorBrush x:Key="Brush_TextSecondary" Color="{StaticResource Color_TextSecondary}" />
    <SolidColorBrush x:Key="Brush_Online" Color="{StaticResource Color_Online}" />
    <SolidColorBrush x:Key="Brush_Offline" Color="{StaticResource Color_Offline}" />
    <SolidColorBrush x:Key="Brush_GroupControlBorder" Color="{StaticResource Color_GroupControlBorder}" />
    <SolidColorBrush x:Key="Brush_Error" Color="{StaticResource Color_Error}" />
    <SolidColorBrush x:Key="Brush_HoverBackground" Color="{StaticResource Color_HoverBackground}" />
    <SolidColorBrush x:Key="Brush_PressedBackground" Color="{StaticResource Color_PressedBackground}" />
    <SolidColorBrush x:Key="Brush_ThumbnailBackground" Color="{StaticResource Color_ThumbnailBackground}" />

    <!-- 字体 -->
    <FontFamily x:Key="Font_Normal">Microsoft YaHei, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font_Monospace">Cascadia Code, Consolas, monospace</FontFamily>

    <!-- ════════════════════════════════════════ -->
    <!-- 全局默认样式                             -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Brush_Background}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font_Normal}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 菜单样式                                -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource Brush_ToolbarBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{StaticResource Brush_ToolbarBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource Brush_ToolbarBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Divider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HasDropShadow" Value="False" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 文本框样式                              -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Brush_CardBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Divider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush_SelectedHighlight}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush_TextSecondary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 密码框样式                              -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource Brush_CardBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Divider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush_SelectedHighlight}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush_TextSecondary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 按钮样式                                -->
    <!-- ════════════════════════════════════════ -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="48" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush_HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush_PressedBackground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Brush_TextSecondary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Brush_SelectedHighlight}" />
        <Setter Property="Padding" Value="14,4" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3b7bff" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#0d47c4" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 下拉框样式                              -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Brush_CardBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Divider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 列表视图样式                            -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="ListView">
        <Setter Property="Background" Value="{StaticResource Brush_Background}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush_SelectedHighlight}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush_HoverBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 状态栏样式                              -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource Brush_ToolbarBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="StatusBarItem">
        <Setter Property="Foreground" Value="{StaticResource Brush_TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 分隔线样式                              -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Brush_Divider}" />
        <Setter Property="Margin" Value="4,4" />
        <Setter Property="Width" Value="1" />
    </Style>

    <Style x:Key="ToolBarSeparatorStyle" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Brush_Divider}" />
        <Setter Property="Margin" Value="4,4" />
        <Setter Property="Width" Value="1" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 滚动条样式                              -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource Brush_Background}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Divider}" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 复选框样式                              -->
    <!-- ════════════════════════════════════════ -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush_TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!-- 群控状态边框样式                        -->
    <!-- ════════════════════════════════════════ -->
    <Style x:Key="GroupControlBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="2" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsGroupControlActive}" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Brush_GroupControlBorder}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
