prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include/freerdp3/
libs=-lfreerdp-client3

Name: FreeRDP client
Description: FreeRDP: A Remote Desktop Protocol Implementation
URL: http://www.freerdp.com/
Version: 3.26.0
Requires: freerdp3
Requires.private: 
Libs: -L${libdir} ${libs}
Libs.private: 
Cflags: -I${includedir}
